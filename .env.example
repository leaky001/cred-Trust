# Contract addresses (from npm run deploy:local or deploy to testnet)
NEXT_PUBLIC_LOAN_FACTORY_ADDRESS=
NEXT_PUBLIC_CREDIT_SCORE_ADDRESS=

# Chain ID: default to local Hardhat (31337). For Creditcoin testnet, replace with the testnet chain id.
NEXT_PUBLIC_CHAIN_ID=31337

# Developer: add your local private key here for scripts only (DO NOT COMMIT real keys)
# Example (local only): PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# After you run `node scripts/deploy.js` the script prints lines you can paste here:
# NEXT_PUBLIC_LOAN_FACTORY_ADDRESS=0x...
# NEXT_PUBLIC_CREDIT_SCORE_ADDRESS=0x...

# For production/testnet deployments, use environment variables set in your shell
# or CI secret stores (do not commit secrets to the repo).
